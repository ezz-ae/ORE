# ============================================================================
# Freehold / ORE — Environment Variables
# ============================================================================
# Copy to .env.local for local dev. In production, set these in:
#   Vercel → Project "ore" → Settings → Environment Variables
#
# Legend:  [REQUIRED] app/feature breaks without it
#          [OPTIONAL] feature degrades gracefully / uses mock fallback
#          [AUTO]     injected automatically by Vercel — do NOT set manually
# ============================================================================


# ── Core: URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=            # [REQUIRED] e.g. https://ore-mu.vercel.app — used by API self-calls & emails
NEXT_PUBLIC_SITE_URL=            # [REQUIRED] public canonical site URL (SEO/metadata)
NEXT_PUBLIC_APP_URL=             # [OPTIONAL] app URL if different from site
METADATA_BASE=                   # [OPTIONAL] overrides metadataBase for OG tags
# VERCEL_URL                     # [AUTO] preview deployment URL
# VERCEL_PROJECT_PRODUCTION_URL  # [AUTO] production URL
# NODE_ENV                       # [AUTO] development | production


# ── Core: Database (Neon / Postgres) ────────────────────────────────────────
DATABASE_URL=                    # [REQUIRED] primary Neon pooled connection string
NEON_DATABASE_URL=               # [OPTIONAL] alias checked before DATABASE_URL
DIRECT_DATABASE_URL=             # [OPTIONAL] non-pooled connection (migrations)
DB_SCHEMA=                       # [OPTIONAL] schema name (default: public)


# ── AI: Gemini (public site AI, broker chat, lead messages, brochure parse) ──
GEMINI_API_KEY=                  # [REQUIRED for public AI] Google AI Studio key
GEMINI_MODEL=                    # [OPTIONAL] default model id (e.g. gemini-2.0-flash)
GEMINI_MODEL_FALLBACKS=          # [OPTIONAL] comma-separated fallback model ids


# ── AI: Vertex AI (Marketing Expert + Intelligence Server AI) ────────────────
# Powers /freehold-intelligence AI chat, CRM AiPrompt, Google Ads sidebar.
# Provide EITHER the service-account JSON (preferred) OR an API key.
VERTEX_AI_SERVICE_ACCOUNT_JSON=  # [REQUIRED for server AI] full JSON of vertex-express SA (one line)
VERTEX_AI_API_KEY=              # [OPTIONAL] alternative to the SA JSON
# Vertex / Agent Engine runtime (for the deployed reasoning engine):
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
NUM_WORKERS=1


# ── AI: Anthropic (WhatsApp recap + AI assist) ───────────────────────────────
ANTHROPIC_API_KEY=               # [OPTIONAL] WhatsApp recap & ai-assist routes


# ── CRM: HubSpot ─────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=            # [OPTIONAL] live CRM sync; falls back to mock data


# ── Ads: Meta (Facebook/Instagram Marketing API) ─────────────────────────────
META_ACCESS_TOKEN=               # [OPTIONAL] live Meta Ads; without it Meta features error on use
META_AD_ACCOUNT_ID=              # [OPTIONAL] act_XXXXXXXXXX
META_PAGE_ID=                    # [OPTIONAL]
META_PIXEL_ID=                   # [OPTIONAL]


# ── Ads: Google Ads API ──────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=      # [OPTIONAL] live Google Ads; without it Ads features error on use
GOOGLE_ADS_CLIENT_ID=            # [OPTIONAL]
GOOGLE_ADS_CLIENT_SECRET=        # [OPTIONAL]
GOOGLE_ADS_REFRESH_TOKEN=        # [OPTIONAL]
GOOGLE_ADS_CUSTOMER_ID=          # [OPTIONAL] 10-digit, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # [OPTIONAL] MCC/manager account id


# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=           # [OPTIONAL] send messages
WHATSAPP_PHONE_NUMBER_ID=        # [OPTIONAL]
WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # [OPTIONAL] inbound webhook verification


# ── Email + notifications (Resend) ───────────────────────────────────────────
RESEND_API_KEY=                  # [OPTIONAL] transactional email
LEADS_FROM_EMAIL=                # [OPTIONAL]
NOTIFICATIONS_FROM_EMAIL=        # [OPTIONAL]
LEADS_NOTIFICATION_EMAIL=        # [OPTIONAL] internal recipient for new leads
CRM_NOTIFICATION_EMAIL=          # [OPTIONAL]
SALES_NOTIFICATION_EMAIL=        # [OPTIONAL]
LEADS_NOTIFICATION_WHATSAPP=     # [OPTIONAL] internal WhatsApp recipient
LEADS_WHATSAPP_WEBHOOK_URL=      # [OPTIONAL] outbound webhook for new leads
CRM_WHATSAPP_WEBHOOK_URL=        # [OPTIONAL]


# ── Storage (S3-compatible object storage) ───────────────────────────────────
STORAGE_ENDPOINT=                # [OPTIONAL] media uploads
STORAGE_ACCESS_KEY_ID=           # [OPTIONAL]
STORAGE_SECRET_ACCESS_KEY=       # [OPTIONAL]
STORAGE_BUCKET=                  # [OPTIONAL]


# ── Auth / admin ─────────────────────────────────────────────────────────────
SESSION_COOKIE_DOMAIN=           # [OPTIONAL] e.g. .freeholdproperty.ae for cross-subdomain sessions
ADMIN_SETUP_KEY=                 # [OPTIONAL] one-time admin bootstrap key
CRM_ADMIN_SETUP_KEY=             # [OPTIONAL] alias checked before ADMIN_SETUP_KEY


# ── Smoke tests (CI only — not runtime) ──────────────────────────────────────
PRODUCTION_URL=                  # [OPTIONAL] scripts/smoke.ts target
STAGING_URL=                     # [OPTIONAL]
VERCEL_BYPASS_TOKEN=             # [OPTIONAL] bypass deployment protection in smoke tests
SMOKE_TIMEOUT_MS=                # [OPTIONAL]
